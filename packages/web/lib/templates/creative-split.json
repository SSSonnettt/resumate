    "education": { "enabled": true, "order": 4, "variant": "compact", "title": "教育" },
    "skills": { "enabled": true, "order": 2, "variant": "tag-cloud", "title": "技能" },
    "projects": { "enabled": true, "order": 5, "variant": "card", "title": "项目作品" },
    "languages": { "enabled": true, "order": 6, "variant": "compact", "title": "语言" }
