{
  "id": "modern-sidebar",
  "name": "Modern Sidebar",
  "nameZh": "现代侧栏",
  "description": "左侧深色边栏展示技能与联系方式，右侧为主内容区",
  "layout": "sidebar-left",
  "colors": {
    "primary": "#1a1a2e",
    "primaryLight": "#16213e",
    "primaryDark": "#0f0f1a",
    "accent": "#e94560",
    "background": "#ffffff",
    "surface": "#f8f9fa",
    "textPrimary": "#1a1a2e",
    "textSecondary": "#495057",
    "textMuted": "#adb5bd",
    "border": "#dee2e6",
    "divider": "#ced4da"
  },
  "typography": {
    "fontFamily": "sans",
    "scale": {
      "h1": "text-2xl leading-8 font-bold",
      "h2": "text-xs leading-5 font-semibold uppercase tracking-[0.15em]",
      "h3": "text-sm leading-5 font-semibold",
      "body": "text-sm leading-6",
      "small": "text-xs leading-5",
      "caption": "text-[10px] leading-4"
    }
  },
  "spacing": "normal",
  "sections": {
    "header": { "enabled": true, "order": 10, "variant": "default", "title": "" },
    "work": { "enabled": true, "order": 20, "variant": "default", "title": "工作经验" },
    "education": { "enabled": true, "order": 30, "variant": "default", "title": "教育背景" },
    "skills": { "enabled": true, "order": 40, "variant": "tag-cloud", "title": "技能" },
    "projects": { "enabled": true, "order": 50, "variant": "default", "title": "项目经验" },
    "languages": { "enabled": true, "order": 60, "variant": "compact", "title": "语言能力" }
  },
  "headerLayout": "centered",
  "sectionDivider": "line"
}
